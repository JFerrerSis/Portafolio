---
import { Terminal as TerminalIcon, X, ChevronRight, Minimize2, Square } from 'lucide-astro';

// Comandos simulados que el usuario podría probar
const commands = [
  { cmd: "whoami", desc: "Muestra info del usuario" },
  { cmd: "ls projects", desc: "Lista los proyectos activos" },
  { cmd: "fetch", desc: "Muestra el neofetch del sistema" },
  { cmd: "clear", desc: "Limpia la pantalla" }
];
---

<div class="w-full bg-[#1e1e1e] border-t border-[--color-editor-border] flex flex-col h-64 md:h-80 select-text font-mono">
  
  <div class="flex items-center justify-between bg-[--color-editor-sidebar] px-4 h-9 border-b border-[--color-editor-border] shrink-0">
    <div class="flex items-center gap-6 h-full">
      <div class="flex items-center gap-2 border-b-2 border-blue-500 h-full px-2 text-white text-[11px] font-bold uppercase tracking-wider">
        <TerminalIcon size={14} class="text-emerald-400" />
        <span>Terminal</span>
      </div>
      <div class="flex items-center gap-2 text-gray-500 text-[11px] hover:text-gray-300 cursor-pointer transition-colors">
        <span>Output</span>
      </div>
      <div class="flex items-center gap-2 text-gray-500 text-[11px] hover:text-gray-300 cursor-pointer transition-colors">
        <span>Debug Console</span>
      </div>
    </div>

    <div class="flex items-center gap-4 text-gray-500">
      <div class="flex gap-2">
        <Minimize2 size={14} class="hover:text-white cursor-pointer" />
        <Square size={12} class="hover:text-white cursor-pointer" />
        <X size={16} class="hover:text-red-500 cursor-pointer" />
      </div>
    </div>
  </div>

  <div id="terminal-body" class="flex-1 overflow-y-auto p-4 text-[13px] leading-relaxed custom-scrollbar">
    <div class="text-gray-500 mb-2">
      Microsoft Windows [Versión 10.0.22631.4317]<br/>
      (c) Microsoft Corporation. Todos los derechos reservados.
    </div>
    
    <div id="terminal-history" class="space-y-1">
      <div class="flex flex-col">
        <div class="flex items-center gap-2">
          <span class="text-emerald-400 font-bold">jferrer@portfolio</span>
          <span class="text-gray-400">:</span>
          <span class="text-blue-400">~</span>
          <span class="text-white">$</span>
          <span class="text-gray-300">system-init --verbose</span>
        </div>
        <p class="text-gray-500 ml-4">Loading system core... [DONE]</p>
        <p class="text-gray-500 ml-4">Connecting to PharosApp API... [CONNECTED]</p>
      </div>
    </div>

    <div class="flex items-center gap-2 mt-2 group">
      <span class="text-emerald-400 font-bold shrink-0">jferrer@portfolio</span>
      <span class="text-gray-400 shrink-0">:</span>
      <span class="text-blue-400 shrink-0">~</span>
      <span class="text-white shrink-0">$</span>
      <input 
        type="text" 
        id="terminal-input" 
        class="bg-transparent border-none outline-none text-gray-200 w-full caret-blue-500"
        autofocus
        spellcheck="false"
        autocomplete="off"
        placeholder="Type 'help'..."
      />
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const input = document.getElementById('terminal-input'); // Asegúrate que tu input tenga este ID
    if (input) {
      // El preventScroll: true es la clave mágica
      input.focus({ preventScroll: true });
    }
  });
</script>

<style>
  #terminal-input {
    font-family: inherit;
    font-size: inherit;
  }
  
  /* Scrollbar discreta para la terminal */
  .custom-scrollbar::-webkit-scrollbar {
    width: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #333;
    border-radius: 4px;
  }
</style>