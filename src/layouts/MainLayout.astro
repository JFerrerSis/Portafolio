---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import EditorTabs from '../components/EditorTabs.astro';
import { ChevronRight, Share2, Search, Command } from 'lucide-astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {/* Se eliminó <ClientRouter /> */}
  </head>
  <body class="flex flex-col h-screen bg-[#1e1e1e] text-editor-text font-mono overflow-hidden selection:bg-editor-text">
    
    <header class="h-9 bg-editor-header border-b border-editor-border flex items-center justify-between px-3 shrink-0 select-none z-50">
      <div class="flex items-center gap-4 w-1/4">
        <div class="flex gap-2 min-w-12.5">
          <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
          <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
          <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
        </div>
        <nav class="hidden xl:flex items-center text-[11px] text-gray-500 gap-1.5 font-medium">
          <span>jferrer</span>
          <ChevronRight size={12} />
          <span>src</span>
          <ChevronRight size={12} />
          <span class="text-gray-300 italic">{title}</span>
        </nav>
      </div>

      <div class="flex-1 max-w-lg mx-auto">
        <div class="bg-editor-hover border border-editor-border rounded-md px-3 py-0.5 flex items-center justify-between group cursor-pointer">
          <div class="flex items-center gap-2 text-gray-400 text-[11px]">
            <Search size={13} />
            <span>portafolio-jose-ferrer</span>
          </div>
          <div class="flex items-center gap-1 text-[10px] text-gray-500 bg-[#1e1e1e] px-1.5 py-0.5 rounded border border-[#333]">
            <Command size={10} />
            <span>P</span>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 w-1/4 text-gray-400">
        <Share2 size={14} class="hover:text-white cursor-pointer" />
      </div>
    </header>

    <div class="flex flex-1 overflow-hidden">
      <Sidebar />

      <main class="flex-1 flex flex-col min-w-0 bg-[#1e1e1e]">
        
        <EditorTabs />

        <div id="main-content" class="flex-1 overflow-y-auto custom-scrollbar relative">
           <slot />
        </div>

      </main>
    </div>

    <Footer />
<script is:inline>
  // Función simplificada: Solo asegura que estemos arriba al cargar
  function initPage() {
    const content = document.getElementById('main-content');
    if (content) {
      content.scrollTop = 0;
    }
  }

  // Se ejecuta al cargar el DOM
  window.addEventListener('DOMContentLoaded', initPage);

  // Por si el navegador intenta restaurar el scroll de una sesión previa
  window.addEventListener('load', () => {
    setTimeout(initPage, 0);
  });
</script>
  </body>
</html>

<style is:global>
  /* Limpieza de clases de animación residuales */
  .animate-in {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }

  /* Scrollbar estilo VS Code */
  .custom-scrollbar::-webkit-scrollbar { width: 10px; height: 10px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #333; border: 2px solid #1e1e1e; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #444; }

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>