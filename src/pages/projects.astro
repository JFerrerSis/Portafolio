---
import MainLayout from '../layouts/MainLayout.astro'; 
import CodeBlock from '../components/CodeBlock.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getGitHubProjects } from '../lib/github';

const GITHUB_USER = "JFerrerSis";
const myProjects = await getGitHubProjects(); 

const initialLine = 1;
const linesPerProject = 5; 
const hasProjects = myProjects.length > 0;
const finalLine = hasProjects 
  ? initialLine + 3 + (myProjects.length * linesPerProject)
  : initialLine + 5;
---

<MainLayout title="projects.ts">
  <section class="max-w-5xl mx-auto py-8 px-4">
    
    <div class="mb-1">
      <CodeBlock line={initialLine} active={true}>
        <span class="text-syntax-control">import</span> 
        <span class="text-syntax-attr">{`{ getGitHubProjects }`}</span> 
        <span class="text-syntax-control">from</span> 
        <span class="text-syntax-string">"../lib/github"</span><span class="text-gray-400">;</span>
      </CodeBlock>
      
      <CodeBlock line={initialLine + 1}>
        <span class="text-syntax-tag">const</span> 
        <span class="text-syntax-attr">data</span> <span class="text-gray-400">=</span> 
        <span class="text-syntax-control">await</span> 
        <span class="text-syntax-func">getGitHubProjects</span><span class="text-gray-400">();</span>
      </CodeBlock>
    </div>

    {hasProjects ? (
      <>
        <div class="flex flex-col gap-0.5">
          {myProjects.map((project, index) => (
            <ProjectCard 
              name={project.name}
              description={project.description || "No description available."}
              stack={project.topics.length > 0 ? project.topics : [project.language || "Code"]}
              url={project.html_url}
              startLine={initialLine + 2 + (index * linesPerProject)} 
            />
          ))}
        </div>
        <div class="mt-0.5">
          <CodeBlock line={finalLine}>
            <span class="text-gray-300 font-bold">{"];"}</span>
          </CodeBlock>
        </div>
      </>
    ) : (
      <div class="mt-4">
        <CodeBlock line={initialLine + 2}>
          <span class="text-[#f44747]">try</span> <span class="text-gray-400">&#123;</span>
        </CodeBlock>
        <CodeBlock line={initialLine + 3}>
          <span class="ml-8 text-[#f44747]">throw new</span> 
          <span class="text-syntax-type"> Error</span><span class="text-gray-400">(</span>
          <span class="text-syntax-string">"No se encontro ningun proyecto disponible"</span>
          <span class="text-gray-400">);</span>
        </CodeBlock>
        <CodeBlock line={initialLine + 4}>
          <span class="text-gray-400">&#125;</span> <span class="text-[#f44747]">catch</span> 
          <span class="text-gray-400">(</span><span class="text-syntax-attr">err</span><span class="text-gray-400">) &#123;</span>
        </CodeBlock>
        <CodeBlock line={initialLine + 5}>
          <span class="ml-8 text-syntax-func">console</span><span class="text-gray-400">.</span>
          <span class="text-syntax-func">error</span><span class="text-gray-400">(</span>
          <span class="text-syntax-attr">err</span><span class="text-gray-400">);</span>
        </CodeBlock>
        <CodeBlock line={initialLine + 6}>
          <span class="text-gray-400">&#125;</span>
        </CodeBlock>
      </div>
    )}

  </section>
</MainLayout>